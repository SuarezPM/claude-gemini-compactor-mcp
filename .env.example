# ── Provider API Keys ──────────────────────────────────────────────────────────
# At least one cloud key required. Gemini recommended (1M context).

# Gemini — best for large file ingestion (1M token context)
GEMINI_API_KEY=your_google_ai_studio_key_here

# DeepSeek — cheapest quality option ($0.27/M input)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Groq — fastest inference (~200ms). Free tier available.
GROQ_API_KEY=your_groq_key_here

# OpenRouter — free-tier fallback models, 1M context
OPENROUTER_API_KEY=your_openrouter_key_here

# Ollama — local/offline inference. No API key needed.
# Override the default base URL if Ollama runs on a different port.
# OLLAMA_BASE_URL=http://localhost:11434/v1
