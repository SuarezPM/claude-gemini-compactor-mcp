# ── Provider API Keys ──────────────────────────────────────────────────────────
# v6.0 — 3 providers: Groq (cloud fast) + OpenRouter (cloud fallback) + Ollama (local free)

# Groq — fastest cloud inference (~200ms). Free tier available.
GROQ_API_KEY=your_groq_key_here

# OpenRouter — free-tier models (1M+ context), cloud fallback.
OPENROUTER_API_KEY=your_openrouter_key_here

# Ollama — local/offline inference. No API key needed.
# Default: http://localhost:11434 (no /v1 suffix)
# OLLAMA_BASE_URL=http://localhost:11434
